<script>
// ============================================================
// STATE
// ============================================================
const state = {
  sessionOpen: null,
  sessionsVisited: new Set(),
  sessionsCompleted: new Set(),
  quizState: {
    s1: { answers: {}, score: 0, total: 5, checked: {} },
    s2: { answers: {}, score: 0, total: 5, checked: {} },
    s3: { answers: {}, score: 0, total: 5, checked: {} }
  }
};

// ============================================================
// HAMBURGER / MOBILE SIDEBAR
// ============================================================
document.getElementById('hamburgerBtn').addEventListener('click', function() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebarOverlay').classList.toggle('show');
});
document.getElementById('sidebarOverlay').addEventListener('click', function() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('show');
});

// ============================================================
// SIDEBAR NAV
// ============================================================
function toggleNavSection(num) {
  const sub = document.getElementById('navSub' + num);
  const btn = document.getElementById('navBtn' + num);
  const isOpen = sub.classList.contains('open');
  // Close all
  [1,2,3].forEach(n => {
    document.getElementById('navSub' + n).classList.remove('open');
    document.getElementById('navBtn' + n).classList.remove('expanded', 'active');
  });
  if (!isOpen) {
    sub.classList.add('open');
    btn.classList.add('expanded', 'active');
  }
}

function scrollToSection(id) {
  document.getElementById(id).scrollIntoView({ behavior: 'smooth', block: 'start' });
  // Mark nav overview active
  document.querySelectorAll('.nav-overview').forEach(el => el.classList.add('active'));
  closeMobileSidebar();
}

function closeMobileSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('show');
}

// ============================================================
// SESSION ACCORDION
// ============================================================
function toggleSession(num) {
  const acc = document.getElementById('acc' + num);
  const body = document.getElementById('body' + num);
  const isOpen = acc.classList.contains('open');

  if (isOpen) {
    acc.classList.remove('open');
    body.classList.remove('open');
  } else {
    acc.classList.add('open');
    body.classList.add('open');
    markVisited(num);
    // Scroll to session after brief delay
    setTimeout(() => {
      document.getElementById('session' + num).scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 100);
  }
}

function openSession(num, tab) {
  // Expand session if not open
  const acc = document.getElementById('acc' + num);
  const body = document.getElementById('body' + num);
  if (!acc.classList.contains('open')) {
    acc.classList.add('open');
    body.classList.add('open');
    markVisited(num);
  }
  // Switch to tab
  const tabMap = { 'objectives': 0, 'topics': 1, 'activity': 2, 'quiz': 3 };
  const tabBtns = document.querySelectorAll(`#body${num} .tab-btn`);
  if (tabBtns[tabMap[tab]]) {
    switchTab(num, tab, tabBtns[tabMap[tab]]);
  }
  // Scroll
  setTimeout(() => {
    document.getElementById('session' + num).scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 100);
  closeMobileSidebar();
}

// ============================================================
// TABS
// ============================================================
function switchTab(sessionNum, tabName, btn) {
  // Deactivate all tabs in this session
  const bodyEl = document.getElementById('body' + sessionNum);
  bodyEl.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  bodyEl.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));

  // Activate selected
  if (btn) btn.classList.add('active');
  const panel = document.getElementById('s' + sessionNum + '-' + tabName);
  if (panel) panel.classList.add('active');
}

// ============================================================
// PROGRESS
// ============================================================
function markVisited(num) {
  if (state.sessionsCompleted.has(num)) return;
  state.sessionsVisited.add(num);
  const step = document.getElementById('step-' + num);
  if (step && !step.classList.contains('completed')) {
    step.classList.add('visited');
    step.querySelector('.step-icon').textContent = '●';
  }
  // Update status badge
  const status = document.getElementById('acc' + num + '-status');
  if (status && !state.sessionsCompleted.has(num)) {
    status.textContent = 'In Progress';
    status.className = 'acc-status in-progress';
  }
  updateNavBtn(num);
}

function markComplete(num) {
  state.sessionsCompleted.add(num);
  state.sessionsVisited.add(num);

  const btn = document.getElementById('complete-btn-' + num);
  btn.classList.add('done');
  btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Session ' + num + ' Completed!';

  const step = document.getElementById('step-' + num);
  step.classList.remove('visited');
  step.classList.add('completed');
  step.querySelector('.step-icon').innerHTML = '&#10003;';

  const status = document.getElementById('acc' + num + '-status');
  status.textContent = 'Completed';
  status.className = 'acc-status completed';

  updateProgressBar();
  updateNavBtn(num);
}

function updateProgressBar() {
  const completed = state.sessionsCompleted.size;
  const pct = Math.round((completed / 3) * 100);
  document.getElementById('sidebarProgressFill').style.width = pct + '%';
  document.getElementById('sidebarProgressLabel').textContent = completed + ' of 3 sessions completed';
}

function updateNavBtn(num) {
  const btn = document.getElementById('navBtn' + num);
  if (state.sessionsCompleted.has(num)) {
    btn.querySelector('.session-num').textContent = '✓';
    btn.querySelector('.session-num').style.background = 'var(--green)';
  }
}

// ============================================================
// QUIZ LOGIC
// ============================================================
function selectOption(session, question, option) {
  const qs = state.quizState[session];
  if (qs.checked[question]) return; // Already answered

  // Clear previous selection visuals
  ['a','b','c','d'].forEach(opt => {
    const el = document.querySelector(`#${session}-${question} .quiz-option:nth-child(${['a','b','c','d'].indexOf(opt)+1})`);
    if (el) {
      el.classList.remove('selected');
    }
  });

  // Set new selection
  qs.answers[question] = option;
  const opts = document.querySelectorAll(`#${session}-${question} .quiz-option`);
  opts.forEach((opt, idx) => {
    opt.classList.remove('selected');
  });

  // Find and highlight selected option
  const optIndex = ['a','b','c','d'].indexOf(option);
  if (opts[optIndex]) opts[optIndex].classList.add('selected');
}

function checkAnswer(session, question, correct, explanation) {
  const qs = state.quizState[session];
  if (qs.checked[question]) return; // Already checked

  const selected = qs.answers[question];
  if (!selected) {
    alert('Please select an answer first!');
    return;
  }

  qs.checked[question] = true;
  const isCorrect = selected === correct;
  if (isCorrect) qs.score++;

  // Disable all options
  const opts = document.querySelectorAll(`#${session}-${question} .quiz-option`);
  opts.forEach((opt, idx) => {
    opt.classList.add('disabled');
    const optLetter = ['a','b','c','d'][idx];
    if (optLetter === correct) opt.classList.add('correct');
    if (optLetter === selected && !isCorrect) opt.classList.add('incorrect');
  });

  // Show feedback
  const feedback = document.getElementById(`${session}-${question}-feedback`);
  feedback.className = 'quiz-feedback show ' + (isCorrect ? 'correct' : 'incorrect');
  feedback.innerHTML = (isCorrect ? '&#10003; <strong>Correct!</strong> ' : '&#10007; <strong>Incorrect.</strong> ') + explanation;

  // Disable check button
  const questionEl = document.getElementById(`${session}-${question}`);
  questionEl.classList.add('answered');
  const checkBtn = questionEl.querySelector('.quiz-check-btn');
  if (checkBtn) checkBtn.disabled = true;

  // Update score display
  const answered = Object.keys(qs.checked).length;
  document.getElementById(`${session}-score-display`).textContent = `Score: ${qs.score} / ${qs.total}`;

  // Check if all questions answered
  if (answered === qs.total) {
    showQuizResults(session, qs.score, qs.total);
  }
}

function showQuizResults(session, score, total) {
  const resultsEl = document.getElementById(`${session}-quiz-results`);
  const scoreBig = document.getElementById(`${session}-score-big`);
  const scoreMsg = document.getElementById(`${session}-score-msg`);
  
  resultsEl.classList.add('show');
  scoreBig.textContent = score + '/' + total;

  let msg = '';
  const pct = (score / total) * 100;
  if (pct === 100) msg = '🎉 Perfect score! Excellent work on Session ' + session.slice(1) + '!';
  else if (pct >= 80) msg = 'Great job! You have a strong understanding of this session.';
  else if (pct >= 60) msg = 'Good effort! Review the topics where you made mistakes.';
  else msg = 'Keep studying! Review the session content and try again.';
  
  scoreMsg.textContent = msg;

  // Change score color based on performance
  if (pct === 100) scoreBig.style.color = 'var(--green)';
  else if (pct >= 60) scoreBig.style.color = 'var(--blue)';
  else scoreBig.style.color = 'var(--red)';
}

function retakeQuiz(session, total) {
  const qs = state.quizState[session];
  qs.answers = {};
  qs.score = 0;
  qs.checked = {};

  // Reset all question elements
  for (let i = 1; i <= total; i++) {
    const qEl = document.getElementById(`${session}-q${i}`);
    if (!qEl) continue;
    qEl.classList.remove('answered');
    
    // Reset options
    qEl.querySelectorAll('.quiz-option').forEach(opt => {
      opt.classList.remove('selected', 'correct', 'incorrect', 'disabled');
    });

    // Hide feedback
    const fb = document.getElementById(`${session}-q${i}-feedback`);
    if (fb) { fb.className = 'quiz-feedback'; fb.innerHTML = ''; }

    // Re-enable check button
    const btn = qEl.querySelector('.quiz-check-btn');
    if (btn) btn.disabled = false;
  }

  // Reset score display
  document.getElementById(`${session}-score-display`).textContent = `Score: 0 / ${total}`;

  // Hide results
  const resultsEl = document.getElementById(`${session}-quiz-results`);
  if (resultsEl) resultsEl.classList.remove('show');
}

// ============================================================
// KEYBOARD ACCESSIBILITY
// ============================================================
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('show');
  }
});

// ============================================================
// SMOOTH APPEARANCE ON LOAD
// ============================================================
window.addEventListener('load', function() {
  document.body.style.opacity = '0';
  document.body.style.transition = 'opacity 0.4s ease';
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      document.body.style.opacity = '1';
    });
  });
});

// ============================================================
// INTERSECTION OBSERVER — auto-mark visited on scroll
// ============================================================
if ('IntersectionObserver' in window) {
  const sessionObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        if (id === 'session1') markVisited(1);
        if (id === 'session2') markVisited(2);
        if (id === 'session3') markVisited(3);
      }
    });
  }, { threshold: 0.2 });

  ['session1','session2','session3'].forEach(id => {
    const el = document.getElementById(id);
    if (el) sessionObserver.observe(el);
  });
}
