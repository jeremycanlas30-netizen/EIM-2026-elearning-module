<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EIM-2026 | Week 1 — Electrical System Installation and Wiring Works</title>
<style>
/* ============================================================
   RESET & BASE
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }
body {
  font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
  background: #f0f4f8;
  color: #1a2332;
  line-height: 1.6;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ============================================================
   CSS VARIABLES
   ============================================================ */
:root {
  --navy: #0b2545;
  --navy-mid: #1a3a5c;
  --blue: #1565c0;
  --blue-light: #1976d2;
  --blue-pale: #e3f0fc;
  --gold: #f5a623;
  --gold-dark: #d4860d;
  --gold-pale: #fff8e1;
  --white: #ffffff;
  --gray-50: #f8fafc;
  --gray-100: #f0f4f8;
  --gray-200: #e2e8f0;
  --gray-300: #cbd5e1;
  --gray-400: #94a3b8;
  --gray-500: #64748b;
  --gray-600: #475569;
  --gray-700: #334155;
  --gray-800: #1e293b;
  --green: #16a34a;
  --green-pale: #dcfce7;
  --red: #dc2626;
  --red-pale: #fee2e2;
  --sidebar-width: 280px;
  --header-height: 80px;
  --radius: 10px;
  --shadow: 0 2px 12px rgba(11,37,69,0.10);
  --shadow-lg: 0 8px 32px rgba(11,37,69,0.15);
  --transition: 0.22s ease;
}

/* ============================================================
   SCROLLBAR
   ============================================================ */
::-webkit-scrollbar { width: 7px; height: 7px; }
::-webkit-scrollbar-track { background: var(--gray-100); }
::-webkit-scrollbar-thumb { background: var(--gray-300); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: var(--blue); }

/* ============================================================
   HEADER
   ============================================================ */
.site-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: var(--header-height);
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 60%, #1a5276 100%);
  color: var(--white);
  display: flex;
  align-items: center;
  padding: 0 24px;
  z-index: 200;
  box-shadow: 0 2px 16px rgba(0,0,0,0.25);
}
.header-brand {
  display: flex;
  flex-direction: column;
  flex: 1;
}
.header-brand .course-tag {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 2px;
}
.header-brand .course-title {
  font-size: 17px;
  font-weight: 700;
  letter-spacing: 0.2px;
  color: var(--white);
  line-height: 1.2;
}
.header-brand .course-sub {
  font-size: 12px;
  color: rgba(255,255,255,0.72);
  margin-top: 2px;
}
.header-badge {
  background: rgba(245,166,35,0.18);
  border: 1.5px solid var(--gold);
  border-radius: 20px;
  padding: 5px 14px;
  font-size: 12px;
  font-weight: 600;
  color: var(--gold);
  white-space: nowrap;
  margin-left: 16px;
}
.hamburger {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  margin-right: 14px;
  padding: 6px;
  color: var(--white);
  flex-shrink: 0;
}
.hamburger svg { display: block; }

/* ============================================================
   LAYOUT SHELL
   ============================================================ */
.app-shell {
  display: flex;
  margin-top: var(--header-height);
  min-height: calc(100vh - var(--header-height));
}

/* ============================================================
   SIDEBAR
   ============================================================ */
.sidebar {
  width: var(--sidebar-width);
  background: var(--navy);
  color: var(--white);
  position: fixed;
  top: var(--header-height);
  left: 0;
  bottom: 0;
  overflow-y: auto;
  z-index: 100;
  transition: transform var(--transition);
  display: flex;
  flex-direction: column;
}
.sidebar-header {
  padding: 20px 20px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.10);
  flex-shrink: 0;
}
.sidebar-header h2 {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--gold);
  margin-bottom: 4px;
}
.sidebar-header p {
  font-size: 12px;
  color: rgba(255,255,255,0.60);
  line-height: 1.4;
}
.sidebar-nav {
  padding: 10px 0 20px;
  flex: 1;
}
.nav-overview {
  display: block;
  padding: 10px 20px;
  font-size: 13px;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  text-decoration: none;
  border-left: 3px solid transparent;
  transition: all var(--transition);
  cursor: pointer;
}
.nav-overview:hover, .nav-overview.active {
  background: rgba(255,255,255,0.08);
  border-left-color: var(--gold);
  color: var(--white);
}
.nav-section {
  margin-top: 6px;
}
.nav-section-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 10px 20px;
  background: none;
  border: none;
  border-left: 3px solid transparent;
  color: rgba(255,255,255,0.90);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  text-align: left;
  transition: all var(--transition);
}
.nav-section-btn:hover {
  background: rgba(255,255,255,0.08);
  border-left-color: var(--gold);
  color: var(--white);
}
.nav-section-btn.active {
  background: rgba(245,166,35,0.15);
  border-left-color: var(--gold);
  color: var(--gold);
}
.nav-section-btn .session-num {
  background: var(--blue);
  border-radius: 50%;
  width: 20px;
  height: 20px;
  font-size: 11px;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 8px;
  flex-shrink: 0;
  transition: background var(--transition);
}
.nav-section-btn.active .session-num, .nav-section-btn:hover .session-num {
  background: var(--gold-dark);
}
.nav-section-btn .chevron {
  transition: transform var(--transition);
  opacity: 0.6;
  flex-shrink: 0;
}
.nav-section-btn.expanded .chevron { transform: rotate(90deg); }
.nav-sub {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.32s ease;
}
.nav-sub.open { max-height: 200px; }
.nav-sub a {
  display: block;
  padding: 7px 20px 7px 46px;
  font-size: 12px;
  color: rgba(255,255,255,0.65);
  text-decoration: none;
  transition: all var(--transition);
  cursor: pointer;
}
.nav-sub a:hover, .nav-sub a.active {
  color: var(--gold);
  background: rgba(255,255,255,0.06);
}
.nav-sub a::before {
  content: '—';
  margin-right: 6px;
  opacity: 0.4;
  font-size: 10px;
}
.sidebar-progress {
  padding: 16px 20px;
  border-top: 1px solid rgba(255,255,255,0.10);
  flex-shrink: 0;
}
.sidebar-progress p {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: rgba(255,255,255,0.50);
  margin-bottom: 8px;
}
.progress-bar-wrap {
  background: rgba(255,255,255,0.12);
  border-radius: 6px;
  height: 6px;
  overflow: hidden;
}
.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--gold), #ffcc02);
  border-radius: 6px;
  transition: width 0.6s ease;
}
.progress-label {
  font-size: 12px;
  color: var(--gold);
  margin-top: 5px;
  font-weight: 600;
}

/* ============================================================
   MAIN CONTENT
   ============================================================ */
.main-content {
  margin-left: var(--sidebar-width);
  flex: 1;
  padding: 32px 28px 60px;
  max-width: 900px;
}

/* ============================================================
   PROGRESS TRACKER
   ============================================================ */
.progress-tracker {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--white);
  border-radius: var(--radius);
  padding: 16px 22px;
  margin-bottom: 28px;
  box-shadow: var(--shadow);
  flex-wrap: wrap;
}
.progress-tracker h3 {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--gray-500);
  margin-right: 4px;
  flex-shrink: 0;
}
.progress-step {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 6px 14px;
  border-radius: 20px;
  background: var(--gray-100);
  border: 2px solid var(--gray-200);
  font-size: 12px;
  font-weight: 600;
  color: var(--gray-500);
  transition: all var(--transition);
}
.progress-step.visited {
  background: var(--blue-pale);
  border-color: var(--blue-light);
  color: var(--blue);
}
.progress-step.completed {
  background: var(--green-pale);
  border-color: var(--green);
  color: var(--green);
}
.progress-step .step-icon {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: var(--gray-300);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  transition: background var(--transition);
}
.progress-step.visited .step-icon { background: var(--blue-light); color: var(--white); }
.progress-step.completed .step-icon { background: var(--green); color: var(--white); }

/* ============================================================
   CARDS / SECTIONS
   ============================================================ */
.card {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 24px;
  overflow: hidden;
  transition: box-shadow var(--transition);
}
.card:hover { box-shadow: var(--shadow-lg); }

/* ============================================================
   WELCOME SECTION
   ============================================================ */
.welcome-hero {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 50%, #1a5276 100%);
  color: var(--white);
  border-radius: var(--radius);
  padding: 36px 32px;
  margin-bottom: 24px;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}
.welcome-hero::before {
  content: '';
  position: absolute;
  top: -40px; right: -40px;
  width: 220px; height: 220px;
  background: rgba(245,166,35,0.10);
  border-radius: 50%;
}
.welcome-hero::after {
  content: '';
  position: absolute;
  bottom: -60px; left: -20px;
  width: 160px; height: 160px;
  background: rgba(21,101,192,0.20);
  border-radius: 50%;
}
.welcome-hero .week-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(245,166,35,0.20);
  border: 1.5px solid var(--gold);
  border-radius: 20px;
  padding: 4px 14px;
  font-size: 12px;
  font-weight: 700;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 14px;
  position: relative;
  z-index: 1;
}
.welcome-hero h1 {
  font-size: 26px;
  font-weight: 800;
  line-height: 1.25;
  margin-bottom: 10px;
  position: relative;
  z-index: 1;
}
.welcome-hero p {
  font-size: 15px;
  color: rgba(255,255,255,0.82);
  max-width: 560px;
  position: relative;
  z-index: 1;
  line-height: 1.65;
}
.welcome-meta {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 20px;
  position: relative;
  z-index: 1;
}
.meta-chip {
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.22);
  border-radius: 6px;
  padding: 5px 12px;
  font-size: 12px;
  color: rgba(255,255,255,0.88);
  font-weight: 500;
}

/* ============================================================
   SECTION HEADERS
   ============================================================ */
.section-header {
  padding: 20px 24px 16px;
  border-bottom: 1px solid var(--gray-100);
  display: flex;
  align-items: center;
  gap: 12px;
}
.section-num {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: var(--blue);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 800;
  flex-shrink: 0;
}
.section-header h2 {
  font-size: 18px;
  font-weight: 700;
  color: var(--navy);
  flex: 1;
}
.section-header .session-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--gray-400);
  display: block;
  margin-bottom: 2px;
}

/* ============================================================
   SESSION ACCORDION
   ============================================================ */
.session-accordion {
  border: 2px solid var(--gray-200);
  border-radius: var(--radius);
  margin-bottom: 20px;
  overflow: hidden;
  transition: border-color var(--transition);
}
.session-accordion:hover { border-color: var(--blue); }
.session-accordion.active { border-color: var(--blue); }
.session-accordion-btn {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 18px 22px;
  background: var(--white);
  border: none;
  cursor: pointer;
  gap: 14px;
  transition: background var(--transition);
}
.session-accordion-btn:hover { background: var(--blue-pale); }
.session-accordion.active .session-accordion-btn { background: var(--blue-pale); }
.session-accordion-btn .acc-num {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--blue);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 800;
  flex-shrink: 0;
}
.session-accordion-btn .acc-text {
  flex: 1;
  text-align: left;
}
.session-accordion-btn .acc-text .acc-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--gray-400);
  margin-bottom: 2px;
}
.session-accordion-btn .acc-text h3 {
  font-size: 16px;
  font-weight: 700;
  color: var(--navy);
}
.session-accordion-btn .acc-status {
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 12px;
  font-weight: 600;
  flex-shrink: 0;
}
.acc-status.not-started { background: var(--gray-100); color: var(--gray-400); }
.acc-status.in-progress { background: var(--blue-pale); color: var(--blue); }
.acc-status.completed { background: var(--green-pale); color: var(--green); }
.acc-chevron {
  transition: transform 0.3s ease;
  color: var(--gray-400);
  flex-shrink: 0;
}
.session-accordion.open .acc-chevron { transform: rotate(180deg); }
.session-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.5s ease;
}
.session-body.open { max-height: 9999px; }
.session-body-inner { padding: 0 22px 22px; }

/* ============================================================
   TABS
   ============================================================ */
.tab-bar {
  display: flex;
  gap: 2px;
  background: var(--gray-100);
  border-radius: 8px;
  padding: 4px;
  margin: 16px 0;
  flex-wrap: wrap;
}
.tab-btn {
  flex: 1;
  min-width: 80px;
  padding: 8px 14px;
  background: none;
  border: none;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 600;
  color: var(--gray-500);
  cursor: pointer;
  transition: all var(--transition);
  white-space: nowrap;
}
.tab-btn:hover { background: rgba(255,255,255,0.7); color: var(--blue); }
.tab-btn.active {
  background: var(--white);
  color: var(--blue);
  box-shadow: 0 1px 6px rgba(0,0,0,0.10);
}
.tab-panel { display: none; }
.tab-panel.active { display: block; animation: fadeIn 0.25s ease; }

@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

/* ============================================================
   CONTENT STYLES
   ============================================================ */
.objectives-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.objectives-list li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 0;
  border-bottom: 1px solid var(--gray-100);
  font-size: 14px;
  line-height: 1.55;
  color: var(--gray-700);
}
.objectives-list li:last-child { border-bottom: none; }
.objectives-list li::before {
  content: counter(obj-counter);
  counter-increment: obj-counter;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--blue);
  color: var(--white);
  font-size: 11px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}
.objectives-list { counter-reset: obj-counter; }

.topic-block {
  margin-bottom: 22px;
}
.topic-block h4 {
  font-size: 15px;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 8px;
  padding-bottom: 6px;
  border-bottom: 2px solid var(--blue-pale);
  display: flex;
  align-items: center;
  gap: 8px;
}
.topic-block h4::before {
  content: '';
  display: inline-block;
  width: 4px;
  height: 18px;
  background: var(--blue);
  border-radius: 2px;
  flex-shrink: 0;
}
.topic-block p, .topic-block ul, .topic-block ol {
  font-size: 14px;
  color: var(--gray-700);
  line-height: 1.65;
}
.topic-block ul, .topic-block ol {
  padding-left: 20px;
  margin-top: 4px;
}
.topic-block li { margin-bottom: 4px; }

.info-box {
  border-radius: 8px;
  padding: 14px 16px;
  margin: 14px 0;
  font-size: 13.5px;
  line-height: 1.6;
  display: flex;
  gap: 10px;
  align-items: flex-start;
}
.info-box.blue { background: var(--blue-pale); border-left: 4px solid var(--blue); color: var(--navy); }
.info-box.gold { background: var(--gold-pale); border-left: 4px solid var(--gold); color: #7a4b00; }
.info-box.green { background: var(--green-pale); border-left: 4px solid var(--green); color: #14532d; }
.info-box .ib-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }

/* ============================================================
   TABLES
   ============================================================ */
.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13.5px;
  margin: 12px 0;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0,0,0,0.07);
}
.data-table th {
  background: var(--navy);
  color: var(--white);
  padding: 11px 14px;
  text-align: left;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.4px;
}
.data-table td {
  padding: 10px 14px;
  border-bottom: 1px solid var(--gray-200);
  color: var(--gray-700);
  vertical-align: top;
  line-height: 1.5;
}
.data-table tr:nth-child(even) td { background: var(--gray-50); }
.data-table tr:last-child td { border-bottom: none; }
.data-table td strong { color: var(--navy); }

/* ============================================================
   ACTIVITY SECTION
   ============================================================ */
.activity-box {
  background: var(--gold-pale);
  border: 2px solid var(--gold);
  border-radius: 10px;
  padding: 20px 22px;
  margin-top: 6px;
}
.activity-box .activity-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 15px;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 12px;
}
.activity-box .activity-badge {
  background: var(--gold);
  color: var(--white);
  padding: 2px 9px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.activity-box p, .activity-box ul, .activity-box ol {
  font-size: 14px;
  color: var(--gray-700);
  line-height: 1.65;
}
.activity-box ul, .activity-box ol { padding-left: 20px; margin-top: 6px; }
.activity-box li { margin-bottom: 5px; }

/* ============================================================
   QUIZ
   ============================================================ */
.quiz-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 18px;
}
.quiz-header h4 {
  font-size: 16px;
  font-weight: 700;
  color: var(--navy);
}
.quiz-score-display {
  background: var(--blue-pale);
  border: 2px solid var(--blue);
  border-radius: 20px;
  padding: 5px 16px;
  font-size: 13px;
  font-weight: 700;
  color: var(--blue);
}
.quiz-question {
  background: var(--gray-50);
  border: 1px solid var(--gray-200);
  border-radius: 10px;
  padding: 18px 20px;
  margin-bottom: 16px;
  transition: border-color var(--transition);
}
.quiz-question.answered { border-color: var(--gray-300); }
.quiz-q-num {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--blue);
  margin-bottom: 7px;
}
.quiz-q-text {
  font-size: 14.5px;
  font-weight: 600;
  color: var(--gray-800);
  margin-bottom: 14px;
  line-height: 1.5;
}
.quiz-options {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 12px;
}
.quiz-option {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 14px;
  border: 2px solid var(--gray-200);
  border-radius: 8px;
  cursor: pointer;
  transition: all var(--transition);
